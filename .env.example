# ─────────────────────────────────────────────────────────────
# Vertex 2 — variables de entorno
# Copia este archivo como .env.local y completa los valores.
# ─────────────────────────────────────────────────────────────

# Cadena de conexión de Supabase Postgres.
# Usa el "Connection pooling" (Supavisor, puerto 6543) para serverless/Vercel:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Secreto para firmar la sesión JWT (mínimo 32 caracteres).
# Genera uno con:  openssl rand -base64 48
SESSION_SECRET=

# Supabase (para Storage de imágenes/adjuntos en fases posteriores).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Contraseña inicial del seed (opcional; por defecto "Vertex2026!").
SEED_ADMIN_PASSWORD=
